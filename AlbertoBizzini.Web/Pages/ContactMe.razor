@page "/contact-me"
@inject ContactFormModel Model
@inject ContactFormModelFluentValidator Validator
@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<ContactMe> L
@inject IStringLocalizer<ContactFormModel> LM
@inject ISnackbar Snackbar

<PageTitle>@L["PageTitle"] - @SR["WebsiteTitle"]</PageTitle>

<MudText Typo="Typo.body2" Class="pl-2 mb-4">@L["IntroductionText"]</MudText>

<MudForm Model="@Model" @ref="@_form" Validation="@(Validator.ValidateValue)" ValidationDelay="0" class="">
    <MudCard Outlined> 
        <MudCardContent>

            <MudStack Spacing="2">
                <MudTextField @bind-Value="Model.Name"
                              For="@(() => Model.Name)"
                              Label="@LM["NameLabel", Validator.NameMaxLength]"
                              Variant="Variant.Filled"
                              MaxLength="@Validator.NameMaxLength"
                              ShrinkLabel />

                <MudTextField @bind-Value="Model.Email"
                              For="@(() => Model.Email)"
                              Label="@LM["EmailLabel"]"
                              Variant="Variant.Filled"
                              ShrinkLabel />

                <MudTextField @bind-Value="Model.Message"
                              For="@(() => Model.Message)"
                              Label="@LM["MessageLabel", Validator.MessageMaxLength]"
                              MaxLength="@Validator.MessageMaxLength"
                              Clearable
                              Counter="0"
                              ShrinkLabel
                              Sizing="InputSizing.Auto"
                              Lines="4"

                              Variant="Variant.Filled" />
            </MudStack>

            <MudCheckBox @bind-Value="Model.PrivacyAccepted"
                         For="@(() => Model.PrivacyAccepted)"
                         Label="@LM["PrivacyAcceptedLabel"]" />

        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" OnClick="@(async () => await Submit())">@L["SendButtonText"]</MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>

@code {
    private MudForm _form = null!;

    private async Task Submit()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            Snackbar.Add("Submitted!", Severity.Info);
        }
    }
}