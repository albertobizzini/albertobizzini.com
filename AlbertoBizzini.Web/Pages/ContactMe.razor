@page "/contact-me"
@inject ContactFormModel Model
@inject ContactFormModelFluentValidator Validator
@inject IStringLocalizer<ContactFormModel> L
@inject ISnackbar Snackbar

<MudForm Model="@Model" @ref="@_form" Validation="@(Validator.ValidateValue)" ValidationDelay="0">
    <MudCard Outlined> 
        <MudCardContent>

            <MudStack Spacing="2">
                <MudTextField @bind-Value="Model.Name"
                              For="@(() => Model.Name)"
                              Label="@L["NameLabel"]"
                              Variant="Variant.Filled"
                              ShrinkLabel />

                <MudTextField @bind-Value="Model.Email"
                              For="@(() => Model.Email)"
                              Label="@L["EmailLabel"]"
                              Variant="Variant.Filled"
                              ShrinkLabel />

                <MudTextField @bind-Value="Model.Message"
                              For="@(() => Model.Message)"
                              Label="@L["MessageLabel", Validator.MessageMaxLength]"
                              Clearable
                              Counter="0"
                              ShrinkLabel
                              Sizing="InputSizing.Auto"
                              Lines="4"
                              Variant="Variant.Filled" />
            </MudStack>

            <MudCheckBox @bind-Value="Model.PrivacyAccepted"
                         For="@(() => Model.PrivacyAccepted)"
                         Label="@L["PrivacyAcceptedLabel"]" />

        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" OnClick="@(async () => await Submit())">@L["SendButtonText"]</MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>

@code {
    private MudForm _form = null!;

    private async Task Submit()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            Snackbar.Add("Submitted!");
        }
    }
}