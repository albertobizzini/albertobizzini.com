@page "/"
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<Home> L

<PageTitle>@L["PageTitle"] - @SR["WebsiteTitle"]</PageTitle>

<MudExpansionPanels MultiExpansion>

    <MudExpansionPanel Expanded>

        <TitleContent>
            @L["LinksSectionHeaderText"]
        </TitleContent>

        <ChildContent>
            <h2><MudLink Href="https://www.etsy.com/shop/IdeeBizzesche?ref=alberto-bizzini-com">My Etsy shop</MudLink></h2>
            <h2><MudLink Href="https://www.youtube.com/AlbertoBizzini?ref=alberto-bizzini-com">My YouTube channel</MudLink></h2>
        </ChildContent>
    </MudExpansionPanel>
    
    <MudExpansionPanel>

        <TitleContent>
            Available apps
        </TitleContent>

        <ChildContent>
            <MudStack Row Spacing="10" Justify="Justify.FlexStart" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap">

                <MudCard Class="app-card" Elevation="@AppCardElevation">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h4" Color="Color.Primary">Patrimetria</MudText>
                            <MudAlert Severity="Severity.Warning" NoIcon Dense>Only italian language</MudAlert>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">Simulatore andamento patrimonio familiare</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="https://patrimetria.albertobizzini.com/" Target="_blank" Color="Color.Primary">
                            Vai all'applicazione
                        </MudButton>
                    </MudCardActions>
                </MudCard>

                <MudCard Class="app-card" Elevation="@AppCardElevation">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h4" Color="Color.Primary">Collezione treni Pierluigi Cova</MudText>
                            <MudAlert Severity="Severity.Warning" NoIcon Dense>Only italian language</MudAlert>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">Consultazione del catalogo dei modelli di treni della collezione di Pierluigi Cova, disponibili per la vendita agli appassionati di fermodellismo</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="https://treni-cova.albertobizzini.com/" Target="_blank" Color="Color.Primary">
                            Vai all'applicazione
                        </MudButton>
                    </MudCardActions>
                </MudCard>

                <MudCard Class="app-card" Elevation="@AppCardElevation">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h4" Color="Color.Primary">Simulatore rendita B&B</MudText>
                            <MudAlert Severity="Severity.Warning" NoIcon Dense>Only italian language</MudAlert>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">Verifica se è redditizio investire dei soldi per la realizzazione di in Bed & Breakfast</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="https://bnbsimulator.albertobizzini.com/" Target="_blank" Color="Color.Primary">
                            Vai all'applicazione
                        </MudButton>
                    </MudCardActions>
                </MudCard>

                <MudCard Class="app-card" Elevation="@AppCardElevation">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h4" Color="Color.Primary">FinTrack - Finance Tracking</MudText>
                            <MudAlert Severity="Severity.Warning" NoIcon Dense>Not publicly available</MudAlert>
                            <MudAlert Severity="Severity.Info" NoIcon Dense>Italian & english language</MudAlert>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">Keep track of your finance</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="https://fintrack.albertobizzini.com/" Target="_blank" Color="Color.Primary">
                            Go to the application
                        </MudButton>
                    </MudCardActions>
                </MudCard>

            </MudStack>
        </ChildContent>

    </MudExpansionPanel>

</MudExpansionPanels>

@code 
{
    private int AppCardElevation = 10;
}

