@page "/contact-me"
@using FluentValidation
@inject ContactFormViewModel Model
@inject ContactFormViewModelFluentValidator Validator
@inject IStringLocalizer<ContactFormViewModel> L
@inject ISnackbar Snackbar

<MudForm Model="@Model" @ref="@_form" Validation="@(Validator.ValidateValue)" ValidationDelay="0">
    <MudCard>
        <MudCardContent>
            <MudTextField Label="@L["EmailLabel"]" Class="mt-3"
                          @bind-Value="Model.Email" For="@(() => Model.Email)" />
            <MudTextField Label="@L["MessageLabel"]" Class="mt-3" Clearable Counter="0" Sizing="InputSizing.Auto" Lines="4"
                          @bind-Value="Model.Message" For="@(() => Model.Message)" />
            <MudCheckBox Label="@L["PrivacyAcceptedLabel"]" Class="mt-3"
                         @bind-Value="Model.PrivacyAccepted" For="@(() => Model.PrivacyAccepted)" />
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto" OnClick="@(async () => await Submit())">@L["SendButtonText"]</MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>

@code {
    private MudForm _form = null!;

    private async Task Submit()
    {
        await _form.ValidateAsync();

        if (_form.IsValid)
        {
            Snackbar.Add("Submitted!");
        }
    }
}