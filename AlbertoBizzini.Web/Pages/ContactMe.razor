@page "/contact-me"
@using Soenneker.Blazor.Turnstile
@using Soenneker.Blazor.Turnstile.Options
@inject ContactFormModel Model
@inject ContactFormModelFluentValidator Validator
@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<ContactMe> L
@inject IStringLocalizer<ContactFormModel> LM
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<ContactMe> Logger

<PageTitle>@L["PageTitle"] - @SR["WebsiteTitle"]</PageTitle>

<MudText class="page-tile">@L["PageTitle"]</MudText>

<MudText Typo="Typo.body2" Class="pl-2 mb-4">@L["IntroductionText"]</MudText>

<MudContainer MaxWidth="MaxWidth.Small">

    <MudForm Model="@Model" @ref="@_form" Validation="@(Validator.ValidateValue)" ValidationDelay="0">
        <MudCard Outlined>
            <MudCardContent>

                <MudStack Spacing="2">
                    <MudTextField @bind-Value="Model.Name"
                                  For="@(() => Model.Name)"
                                  Label="@LM["NameLabel", Validator.NameMaxLength]"
                                  Variant="Variant.Filled"
                                  MaxLength="@Validator.NameMaxLength"
                                  ShrinkLabel />

                    <MudTextField @bind-Value="Model.Email"
                                  For="@(() => Model.Email)"
                                  Label="@LM["EmailLabel"]"
                                  Variant="Variant.Filled"
                                  ShrinkLabel />

                    <MudTextField @bind-Value="Model.Message"
                                  For="@(() => Model.Message)"
                                  Label="@LM["MessageLabel", Validator.MessageMaxLength]"
                                  MaxLength="@Validator.MessageMaxLength"
                                  Clearable
                                  Counter="0"
                                  ShrinkLabel
                                  Sizing="InputSizing.Auto"
                                  Lines="4"
                                  Variant="Variant.Filled" />

                    @if (!ContactFormModel.IgnorePrivacyPolicy)
                    {
                        <MudStack Row>
                            <MudLink @onclick="OpenPrivacyDialogAsync" Variant="Variant.Text" Color="Color.Primary">
                                @L["ShowPrivacyButtonText"]
                            </MudLink>
                            @if (!Model.PrivacyPolicyViewed)
                            {
                                <MudText Typo="Typo.caption">(@L["PrivacyPolicyAcceptanceHelperTextMessage"])</MudText>
                            }
                        </MudStack>

                        <MudCheckBox @bind-Value="Model.ConfirmedPrivacyPolicyViewed"
                                     For="@(() => Model.ConfirmedPrivacyPolicyViewed)"
                                     Label="@LM["ConfirmedPrivacyPolicyViewedLabel"]"
                                     Disabled="@(!Model.PrivacyPolicyViewed)" />
                    }

                    <MudAlert Severity="Severity.Info" Dense>
                        @LM["Disclaimer"]
                    </MudAlert>

                    <MudCheckBox @bind-Value="Model.ResponsibilityTaken"
                                 For="@(() => Model.ResponsibilityTaken)"
                                 Label="@LM["ResponsibilityTakenLabel"]" />



                    <MudStack Row Justify="Justify.Center">
                        <Turnstile @ref="_turnstile" OnCallback="OnCallback" Options="_options" />
                    </MudStack>

                </MudStack>

            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="ml-auto"
                           Disabled="@SubmitButtonDisabled"
                           OnClick="@(async () => await Submit())">
                    @L["SendButtonText"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudForm>

</MudContainer>

@code {
    private MudForm _form = null!;
    private bool SubmitButtonDisabled => TurnstileTokenIsNull || !Model.ResponsibilityTaken;

    private async Task Submit()
    {
        await _form.ValidateAsync();

        if (!_form.IsValid)
            return;

        if (TurnstileTokenIsNull)
        {
            Snackbar.Add("Turnstile token not set", Severity.Error);

            return;
        }

        Snackbar.Add("Submitted!", Severity.Info);
    }

    private async Task OpenPrivacyDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = false, CloseButton = false };

        var dialog = await DialogService.ShowAsync<ContactMePrivacyDialog>(title: @L["PrivacyDialogTitle"], options: options);
        var result = await dialog.Result;

        if (Model.PrivacyPolicyViewed)
            return;

        Model.PrivacyPolicyViewed = !(result?.Canceled ?? false);
    }

    #region Cloudflare Turnstile

    private Turnstile _turnstile;
    private string? _turnstileToken = null;
    private bool TurnstileTokenIsNull => _turnstileToken is null;

    private readonly TurnstileOptions _options = new()
    {
        SiteKey = "0x4AAAAAAD3M68Tpy8NU_JJK" // Testing key
    };

    private void OnCallback(string token)
    {
        _turnstileToken = token;
        Logger.LogInformation("OnCallback fired, token: {token}", token);
    }

    #endregion

}