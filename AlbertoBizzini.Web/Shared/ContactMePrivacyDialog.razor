@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<Pages.ContactMe> L

<MudDialog>
    <TitleContent>
        @L["ShowPrivacyButtonText"]
    </TitleContent>
    <DialogContent>
        @foreach(var line in Lines)
        {
            <MudText>@line</MudText>
        }
    </DialogContent>
    <DialogActions>
        @* <MudButton OnClick="Cancel">Cancel</MudButton> *@
        <MudButton Color="Color.Primary" OnClick="Submit">@SR["OK"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();

    private string[] Lines => L["Disclaimer"].Value.Split(Environment.NewLine);
}
