@page "/clippings"
@using KindleClippings
@using AlbertoBizzini.Web.Shared
@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<BrowseClippings> L
@inject KindleClippingService KindleService
@inject ILogger<BrowseClippings> Logger


<MudBreakpointProvider OnBreakpointChanged="BreakpointChanged" />

<PageTitle>@L["PageTitle"] - @SR["WebsiteTitle"]</PageTitle>

<MudText class="page-tile">@L["PageTitle"]</MudText>

<MudText Typo="Typo.body2" Class="pl-2 mb-4">@L["IntroductionText"]</MudText>

@if (_loading)
{
    <LoadingProgress />
}

@if (!_loading && _clippings?.Count > 0)
{
    <MudStack Row Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Spacing="2" Class="px-2">
        <MudTextField @bind-Value="_searchString" ShrinkLabel Label="@L["SearchPlaceholder"]" Adornment="Adornment.Start" Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>

        <MudSelect T="string"
                   Value="@_selectedAuthor"
                   ValueChanged="OnAuthorChanged"
                   Label="@L["BookAuthorLabel"]"
                   ShrinkLabel
                   Dense
                   FitContent
                   Clearable>

            @if (_authors?.Count > 0)
            {
                @foreach (var author in _authors)
                {
                    <MudSelectItem Value="author">@author</MudSelectItem>
                }
            }
        </MudSelect>

        @if (!string.IsNullOrWhiteSpace(_selectedAuthor) && _selectedAuthorTitles?.Count > 0)
        {
            <MudSelect @bind-Value="@_selectedTitle"
                       Label="@L["BookTitleLabel"]"
                       ShrinkLabel
                       Dense
                       FitContent
                       Clearable>
                @foreach (var title in _selectedAuthorTitles)
                {
                    <MudSelectItem Value="title">@title</MudSelectItem>
                }
            </MudSelect>

        }
    </MudStack>

}

<MudDataGrid Items="@_clippings"
             Filterable="true"
             MultiSelection="false"
             QuickFilter="@_quickFilter"
             Breakpoint="Breakpoint.None"
             Class="mt-4">

    <NoRecordsContent>
        @L["ThereAreNoItemsMessage"]
    </NoRecordsContent>

    <Columns>
        @if (IsMobile)
        {
            <TemplateColumn>
                <CellTemplate>
                    <ClippingDisplay Clipping="@context.Item" />
                </CellTemplate>
            </TemplateColumn>

        }
        else
        {
            <PropertyColumn Property="x => x.AddedOn" Title="@L["AddedOnLabel"]" Format="d" />
            <PropertyColumn Property="x => x.Book.Author" Title="@L["BookAuthorLabel"]" />
            <PropertyColumn Property="x => x.Book.Title" Title="@L["BookTitleLabel"]" />
            <PropertyColumn Property="x => x.QuotedText" Title="@L["ClippedTextLabel"]" CellStyle="font-style: italic" />
            @* <PropertyColumn Property="x => x.StartLocation" Title="@L["StartLocationLabel"]" Filterable="false" Sortable="false" StickyRight /> *@
        }
    </Columns>

    <PagerContent>
        <MudDataGridPager T="Clipping" />
    </PagerContent>

</MudDataGrid>

@code {
    private bool _loading = true;
    private List<Clipping>? _clippings;
    private List<string> _authors = new();
    private string _searchString = string.Empty;
    private string? _selectedAuthor;
    private string? _selectedTitle;

    private List<string> _selectedAuthorTitles => _clippings is not null && string.IsNullOrWhiteSpace(_selectedAuthor)
        ? new()
        : _clippings!
            .Where(c => c.Book.Author == _selectedAuthor)
            .Select(c => c.Book.Title)
            .Distinct()
            .OrderBy(b => b)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("BrowseClippings.OnInitializedAsync loading clippins...");
        var result = await KindleService.LoadAsync();
        _clippings = result.Clippings;
        Logger.LogInformation("BrowseClippings.OnInitializedAsync loaded {count} clippins...", _clippings?.Count);

        _authors = _clippings
            .Where(c => !string.IsNullOrWhiteSpace(c.Book.Author))
            .Select(c => c.Book.Author!)
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        _loading = false;
    }

    private void OnAuthorChanged(string? author)
    {
        _selectedAuthor = author;
        _selectedTitle = null;
    }

    private Func<Clipping, bool> _quickFilter => c =>
    {
        if (!string.IsNullOrWhiteSpace(_selectedAuthor))
        {
            if (!string.Equals(c.Book.Author, _selectedAuthor, StringComparison.OrdinalIgnoreCase))
                return false;

            if (!string.IsNullOrWhiteSpace(_selectedTitle))
            {
                if (!string.Equals(c.Book.Title, _selectedTitle, StringComparison.OrdinalIgnoreCase))
                    return false;
            }
        }

        // Ricerca libera
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            if (c.Book.Author is not null &&
                c.Book.Author.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
                return true;

            if (c.Book.Title is not null &&
                c.Book.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
                return true;

            if (c.QuotedText is not null &&
                c.QuotedText.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
                return true;

            return false;
        }

        return true;
    };

    #region Breakpoint

    private Breakpoint _breakpoint;

    private Task BreakpointChanged(Breakpoint breakpoint)
    {
        _breakpoint = breakpoint;
        return Task.CompletedTask;
    }

    private bool IsMobile =>
        _breakpoint <= Breakpoint.Sm;

    #endregion

}