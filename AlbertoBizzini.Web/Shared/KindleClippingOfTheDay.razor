@using KindleClippings
@inject KindleClippingService KindleClippingService
@inject IStringLocalizer<SharedResources> SR
@inject IStringLocalizer<KindleClippingOfTheDay> L

@if (_noClippingIsAvailable)
{
	<MudAlert Severity="Severity.Warning">@SR["NoKindleClippingIsAvailableWarningMessage"]</MudAlert>
}
else
{
	<MudStack>
		<KindleClippingDisplay Clipping="@_clipping" HideShareButton/>

		@if (ShowPagination && _clipping is not null)
		{
			<MudStack Row Justify="Justify.Center" AlignItems="AlignItems.Center">
				<MudIconButton Variant="Variant.Outlined" Color="Color.Primary" Icon="@Icons.Material.TwoTone.KeyboardArrowLeft" OnClick="DecreaseDeltaDays" Size="Size.Small" />
				<MudIconButton Variant="Variant.Outlined" Color="Color.Primary" Icon="@Icons.Material.TwoTone.KeyboardArrowRight" OnClick="IncreaseDeltaDays" Disabled="@(DeltaDays == 0)" Size="Size.Small" />
				<KindleShareClippingButton Clipping="_clipping"/>
				<MudLink Href="clippings" Style="text-align:center" Underline="Underline.None">@L["NavToClippingsPage"]…</MudLink>
			</MudStack>

		}
	</MudStack>

}

    
@code {
	[Parameter] public int DeltaDays { get; set; } = 0;
	[Parameter] public bool ShowPagination { get; set; } = true;
	[Parameter] public EventCallback<int> DeltaDaysChanged { get; set; } // Rimosso il Nullable?, EventCallback non è mai null in Blazor

	private Clipping? _clipping;
	private bool _noClippingIsAvailable = false;

	protected override async Task OnParametersSetAsync()
	{
		await GetClipping();
	}

	protected async Task GetClipping()
	{
		// Evita di resettare a null se il componente sta solo rinfrescando i parametri con lo stesso valore
		_clipping = null;
		_noClippingIsAvailable = false;
		StateHasChanged();

		_clipping = await KindleClippingService.GetClippingOfTheDay(DeltaDays);

		if (_clipping is null)
			_noClippingIsAvailable = true;

		StateHasChanged();
	}

	protected async Task DecreaseDeltaDays() => await UpdateDeltaDays(-1);

	protected async Task IncreaseDeltaDays() => await UpdateDeltaDays(+1);

	protected async Task UpdateDeltaDays(int step)
	{
		var newValue = DeltaDays + step;

		// Notifica il genitore passando il nuovo valore.
		// Il genitore aggiornerà il parametro, che scatenerà OnParametersSetAsync -> GetClipping() automaticamente.
		await DeltaDaysChanged.InvokeAsync(newValue);
	}
}
