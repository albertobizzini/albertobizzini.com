@page "/clippings"
@using KindleClippings
@inject KindleClippingService KindleService

<h3>Kindle Clippings</h3>

@if (clippings == null)
{
    <p>Caricamento...</p>
}
else
{
    <p>Totale: @clippings.Count</p>
}

@code {
    private List<Clipping>? clippings;

    protected override async Task OnInitializedAsync()
    {
        var result = await KindleService.LoadAsync();
        clippings = result.Clippings;
    }
}