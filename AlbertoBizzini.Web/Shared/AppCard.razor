@using System.Globalization
@inject IStringLocalizer<AppCard> L
@inject IJSRuntime JS

<MudPaper Elevation="@Elevation" MaxWidth="300px" Class="pa-4" Square="false" @onclick="OpenInNewTab" Style="cursor:pointer">
	<MudStack Row Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
		<MudText Typo="Typo.h6" Color="Color.Primary" Inline Style="font-weight: bolder">
			@AppName
		</MudText>
		@if (!string.IsNullOrWhiteSpace(Version))
		{
			<MudText Typo="Typo.subtitle2" Inline Class="opacity-med" Style="font-weight: 300">@Version</MudText>
		}
	</MudStack>
	<MudPaper Class="mt-2" Elevation="0">
		@ChildContent
	</MudPaper>
	<MudDivider Class="mt-4" />
	<MudStack Row Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" Class="mt-3" AlignItems="AlignItems.Center">
		<MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="@AppLink" Target="_blank" Color="Color.Tertiary" Variant="Variant.Text">
			@L["FollowApplicationLinkText"]
		</MudButton>
		@if (ShowOnlyInItalian)
		{
			<MudAlert Severity="Severity.Warning" NoIcon Dense Style="font-size: 0.8rem">@L["OnlyInItalianMessageText"]</MudAlert>
		}
		@if (EnrollNeeded)
		{
			<MudAlert Severity="Severity.Warning" NoIcon Dense Style="font-size: 0.8rem">@L["EnrollNeededMessageText"]</MudAlert>
		}
	</MudStack>
</MudPaper>

@code
{
	[Parameter] public string? AppName { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public string? AppLink { get; set; }
	[Parameter] public bool OnlyItalian { get; set; } = true;
	[Parameter] public bool EnrollNeeded { get; set; } = false;
	[Parameter] public string? Version { get; set; } = null;
	[Parameter] public int Elevation { get; set; } = 8;

	private bool ShowOnlyInItalian => OnlyItalian && (!CultureInfo.DefaultThreadCurrentCulture?.TwoLetterISOLanguageName.Equals("it", StringComparison.OrdinalIgnoreCase) ?? true);

	private async Task OpenInNewTab()
	{
		await JS.InvokeVoidAsync("open", AppLink, "_blank");
	}
}
