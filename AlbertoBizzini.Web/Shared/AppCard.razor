@using System.Globalization
@inject IStringLocalizer<AppCard> L

<MudCard Class="app-card" Elevation="@Elevation">
	<MudCardHeader>
		<CardHeaderContent>
			<MudText Typo="Typo.h6" Color="Color.Primary">@AppName</MudText>
		</CardHeaderContent>
	</MudCardHeader>
	<MudCardContent>
		@ChildContent
	</MudCardContent>
	<MudCardActions>
		<MudStack Row Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween">
			<MudButton EndIcon="@Icons.Material.TwoTone.OpenInNew" Href="@AppLink" Target="_blank" Color="Color.Tertiary">
				@L["FollowApplicationLinkText"]
			</MudButton>
			@if (ShowOnlyInItalian)
			{
				<MudAlert Severity="Severity.Warning" NoIcon Dense Style="font-size: 0.8rem">@L["OnlyInItalianMessageText"]</MudAlert>
			}
			@if (EnrollNeeded)
			{
				<MudAlert Severity="Severity.Warning" NoIcon Dense Style="font-size: 0.8rem">@L["EnrollNeededMessageText"]</MudAlert>
			}
		</MudStack>
	</MudCardActions>
</MudCard>

@code
{
	[Parameter] public string? AppName { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public string? AppLink { get; set; }
	[Parameter] public bool OnlyItalian { get; set; } = true;
	[Parameter] public bool EnrollNeeded { get; set; } = false;
	[Parameter] public int Elevation { get; set; } = 8;

	private bool ShowOnlyInItalian => OnlyItalian && (!CultureInfo.DefaultThreadCurrentCulture?.TwoLetterISOLanguageName.Equals("it", StringComparison.OrdinalIgnoreCase) ?? true);
}
