@using KindleClippings
@inject IStringLocalizer<KindleClippingDisplay> L

@if (JustTheQuote)
{
    @if (Clipping is null)
    {
        <MudSkeleton />
    }
    else
    {
        <MudStack Row Justify="Justify.FlexStart" AlignItems="AlignItems.Center" StretchItems="StretchItems.Start">
            <MudText HtmlTag="@HtmlTag" Color="@Color"><MudHighlighter Text="@Clipping.QuotedText" HighlightedText="@HighlighterText" /></MudText>

            @if (!HideShareButton)
            {
                <KindleShareClippingButton Clipping="Clipping" />
            }
        </MudStack>
    }
}
else
{
    <MudStack Row Justify="Justify.FlexStart" AlignItems="AlignItems.Center" StretchItems="StretchItems.Start">

        <MudStack>
            <MudPaper Elevation="6" Class="pa-3">
                @if (Clipping is null)
                {
                    <MudSkeleton />
                    <MudSkeleton />
                }
                else
                {
                    <MudText HtmlTag="@HtmlTag" Color="@Color"><MudHighlighter Text="@Clipping.QuotedText" HighlightedText="@HighlighterText" /></MudText>
                }
            </MudPaper>
            @if (Clipping is not null)
            {
                <MudStack Row Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">

                    <MudText Typo="Typo.caption" Align="Align.Right" Class="mt-3" Style="display:block">
                        @L["ExtractedFromLabel"] <MudText Color="Color.Info" Inline>@Clipping.Book.Title</MudText>
                        @if (Clipping.Book.Author is not null)
                        {
                            <MudText Inline="true"> (@Clipping.Book.Author)</MudText>
                        }
                        @if (Clipping.AddedOn is not null)
                        {
                            <MudText Typo="Typo.caption" Class="opacity-med" Style="display:block">(@L["AddedOnLabel"] @Clipping.AddedOn.Value.ToShortDateString() - @L["PositionLabel"]: @Clipping.StartLocation)</MudText>
                        }
                    </MudText>


                </MudStack>

            }
        </MudStack>

        @if (!HideShareButton)
        {
            <KindleShareClippingButton Clipping="Clipping" />
        }

    </MudStack>
}

@code {
    [Parameter] public Clipping Clipping { get; set; }
    [Parameter] public bool JustTheQuote { get; set; } = false;
    [Parameter] public bool HideShareButton { get; set; } = false;
    [Parameter] public string? HighlighterText { get; set; }
    [Parameter] public string HtmlTag { get; set; } = "em";
    [Parameter] public Color Color { get; set; } = Color.Info;
    [Parameter] public Color ShareButtonColor { get; set; } = Color.Primary;





}